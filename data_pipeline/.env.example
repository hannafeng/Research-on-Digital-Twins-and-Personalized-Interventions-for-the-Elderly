# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_EXPIRE_TIME=300

# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=elderly_care
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# InfluxDB配置
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=elderly-care-org
INFLUXDB_BUCKET=elderly-care-bucket

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MQTT配置
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=data_pipeline

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/data_pipeline.log

# 调度配置
SCHEDULE_INTERVAL=300
